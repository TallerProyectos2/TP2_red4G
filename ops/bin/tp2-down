#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../lib/tp2-common.sh
source "${SCRIPT_DIR}/../lib/tp2-common.sh"
tp2_load_config

tp2_log "Stopping TP2 session"

tp2_log "Stopping EPC car control"
tp2_remote_systemctl_quiet "${TP2_EPC_SSH}" stop "${TP2_EPC_CAR_CONTROL_SERVICE}"

tp2_log "Stopping EPC local inference fallback"
tp2_remote_systemctl_quiet "${TP2_EPC_SSH}" stop "${TP2_EPC_LOCAL_INFERENCE_SERVICE}"

if [[ "${TP2_STOP_MOSQUITTO_ON_DOWN}" == "1" ]]; then
  tp2_log "Stopping MQTT broker"
  tp2_remote_systemctl_quiet "${TP2_EPC_SSH}" stop "${TP2_EPC_MQTT_SERVICE}"
fi

tp2_log "Stopping eNodeB radio"
tp2_remote_systemctl_quiet "${TP2_ENB_SSH}" stop "${TP2_ENB_SRSENB_SERVICE}"

tp2_log "Stopping EPC core"
tp2_remote_systemctl_quiet "${TP2_EPC_SSH}" stop "${TP2_EPC_SRSEPC_SERVICE}"

if [[ "${TP2_STOP_JETSON_ON_DOWN}" == "1" && -n "${TP2_JETSON_SSH}" ]]; then
  tp2_log "Stopping Jetson inference"
  tp2_remote_systemctl_quiet "${TP2_JETSON_SSH}" stop "${TP2_JETSON_INFERENCE_SERVICE}"
fi

tp2_log "TP2 shutdown sequence completed"
